{
  "name": "now-os-minimal-fastify-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prestart": "tsx src/workspace_preflight.ts",
    "start": "node dist/server.js",
    "prebuild": "tsx src/workspace_preflight.ts",
    "build": "tsc -p tsconfig.json",
    "provenance:generate": "node scripts/generate-build-provenance.mjs",
    "provenance:verify": "node scripts/verify-build-provenance.mjs",
    "test:package12:real": "tsx scripts/responsesModelQualification.ts",
    "test:package12:combined-real": "tsx scripts/responsesQualificationSuite.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "backup": "tsx scripts/backup.ts",
    "test:spec021": "tsx src/tests/syntheticSpec021.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "adm-zip": "0.6.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "openai": "^4.80.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.10",
    "pm2": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
